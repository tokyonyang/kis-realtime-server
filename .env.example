PORT=3000

# real = 실전, paper = 모의
KIS_ENV=real
KIS_APP_KEY=한국투자증권_APP_KEY
KIS_APP_SECRET=한국투자증권_APP_SECRET
KIS_CUSTTYPE=P

# 처음 테스트는 005930 하나만 권장
WATCH_SYMBOLS=005930

# Supabase 서버 저장용. service_role key는 이 서버 환경변수에만 넣고 GitHub에는 올리지 마세요.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=Supabase_service_role_key

# 같은 종목 Supabase 저장 최소 간격(ms)
QUOTE_WRITE_INTERVAL_MS=1000
